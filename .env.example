# Copy this file to .env and update the values for your environment.
# docker compose automatically loads values from .env in this folder.

# ---------------------------------------------------------------------------
# Core Secrets
# ---------------------------------------------------------------------------
JWT_SECRET=change_this_super_secret_value
INTERNAL_SERVICE_TOKEN=cf_internal_dev_token

# ---------------------------------------------------------------------------
# MongoDB Connections (Atlas URIs or local Mongo)
# Each service uses its own database for true isolation.
# ---------------------------------------------------------------------------
AUTH_MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/AdminDB?retryWrites=true&w=majority
ORDER_MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/OrderDB?retryWrites=true&w=majority
ADMIN_MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/AdminDB?retryWrites=true&w=majority
TICKET_MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/TicketDB?retryWrites=true&w=majority
COMPANY_MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/CompanyDB?retryWrites=true&w=majority

# ---------------------------------------------------------------------------
# Notification / SMTP (Brevo example)
# Replace SMTP_PASS with your real Brevo SMTP key before running in production.
# ---------------------------------------------------------------------------
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-email@smtp-brevo.com
SMTP_PASS=replace_with_your_brevo_smtp_key
NOTIFICATION_FROM=your-email@smtp-brevo.com

# ---------------------------------------------------------------------------
# URLs / Branding
# ---------------------------------------------------------------------------
COMPANY_PORTAL_URL=https://portal.connectfulfillment.dev
CF_BRAND_LOGO_URL=https://dummyimage.com/200x60/1e3a8a/ffffff&text=Connect+Fulfillment
