# .env.example
# Copy this file to .env and fill in your actual values
# Add .env to your .gitignore to prevent committing sensitive information

# ============================================
# MongoDB Atlas Connection Strings
# ============================================
# Key Insight: You do not need to create separate clusters
# Just use separate database names inside one cluster
# MongoDB will automatically create each database the first time you write to it
# ============================================

# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority

# Auth Service - Uses existing 'Admin' database
AUTH_MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/AdminDB?retryWrites=true&w=majority

# Order Service
ORDER_MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/order-db?retryWrites=true&w=majority

# Ticket Service
TICKET_MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/ticket-db?retryWrites=true&w=majority

# Company Service
COMPANY_MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/company-db?retryWrites=true&w=majority

# ============================================
# Auth Service Configuration
# ============================================
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
STAFF_EMAILS_COLLECTION=admin@connectfulfillment.com,manager@connectfulfillment.com,support@connectfulfillment.com,admin@connectfulfillment.co.uk

# ============================================
# Other Services (Redis, Kafka)
# ============================================
# These are typically for Docker Compose internal network
REDIS_URL=redis://redis:6379
KAFKA_BROKERS=kafka:9092